{
  "expo": {
    "name": "PDF Share",
    "slug": "pdf-share",
    "version": "1.0.0",
    "platforms": ["ios", "android", "web"],
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#6366f1"
    },
    "android": {
      "package": "com.monish.pdfshare",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#6366f1"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/images/icon.png"
    }
  }
}